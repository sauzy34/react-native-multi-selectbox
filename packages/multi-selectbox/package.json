{
  "name": "react-native-multi-selectbox",
  "version": "2.0.0",
  "description": "Platform-independent select / multi-select / picker for React Native and Expo (TypeScript).",
  "license": "MIT",
  "author": "Saurav Gupta <sonugupta34@gmail.com> (https://github.com/sauzy34)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauzy34/react-native-multi-selectbox.git",
    "directory": "packages/multi-selectbox"
  },
  "bugs": {
    "url": "https://github.com/sauzy34/react-native-multi-selectbox/issues"
  },
  "homepage": "https://github.com/sauzy34/react-native-multi-selectbox/tree/master/packages/multi-selectbox#readme",
  "keywords": [
    "react-native-select",
    "react-native",
    "selectbox",
    "dropdown",
    "picker",
    "expo"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "build": "tsc -p tsconfig.build.json",
    "lint": "node -e \"console.log('Run pnpm lint from the monorepo root')\"",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-jest": "^30.4.1",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.2"
  }
}
