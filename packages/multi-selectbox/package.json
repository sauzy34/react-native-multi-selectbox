{
  "name": "react-native-multi-selectbox",
  "version": "2.0.0-alpha.0",
  "private": true,
  "description": "Platform independent (Android / iOS) Selectbox | Picker | Multi-select | Multi-picker.",
  "license": "MIT",
  "author": "Saurav Gupta <sonugupta34@gmail.com> (https://github.com/sauzy34)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauzy34/react-native-multi-selectbox.git",
    "directory": "packages/multi-selectbox"
  },
  "bugs": {
    "url": "https://github.com/sauzy34/react-native-multi-selectbox/issues"
  },
  "homepage": "https://github.com/sauzy34/react-native-multi-selectbox/tree/master/packages/multi-selectbox#readme",
  "keywords": [
    "react-native-select",
    "react-native",
    "selectbox",
    "dropdown",
    "picker",
    "expo"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md",
    "!src/**/*.test.tsx",
    "!src/**/*.test.ts",
    "!src/test-utils/**",
    "!jest.config.js"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "build": "node -e \"console.log('[react-native-multi-selectbox] build: deferred until publish pipeline')\"",
    "lint": "node -e \"console.log('[react-native-multi-selectbox] lint: deferred until Phase 7')\"",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "lodash": ">=4.17.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/react": "~19.2.2",
    "babel-jest": "^30.4.1",
    "jest": "^29.7.0",
    "lodash": "^4.17.21",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.2"
  }
}
