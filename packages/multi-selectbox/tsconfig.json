{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js"],
  "exclude": ["**/__tests__", "**/*.test.ts", "**/*.test.tsx", "lib", "dist"]
}
