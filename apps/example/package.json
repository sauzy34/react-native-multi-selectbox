{
  "name": "@rn-multi-selectbox/example",
  "version": "0.0.0",
  "private": true,
  "description": "Expo TypeScript example for react-native-multi-selectbox",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --offline",
    "start:online": "expo start",
    "android": "expo start --offline --android",
    "ios": "expo start --offline --ios",
    "web": "expo start --offline --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('[@rn-multi-selectbox/example] smoke: use pnpm example + package Jest suite')\"",
    "test:ci": "node -e \"console.log('[@rn-multi-selectbox/example] smoke: use pnpm example + package Jest suite')\"",
    "lint": "node -e \"console.log('Run pnpm lint from the monorepo root')\""
  },
  "dependencies": {
    "expo": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "lodash": "^4.17.21",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-multi-selectbox": "workspace:*",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.20",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.33.0"
}
