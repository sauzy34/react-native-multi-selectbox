{
  "name": "react-native-multi-selectbox-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for react-native-multi-selectbox (library) and Expo example app.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauzy34/react-native-multi-selectbox.git"
  },
  "bugs": {
    "url": "https://github.com/sauzy34/react-native-multi-selectbox/issues"
  },
  "author": "Saurav Gupta <sonugupta34@gmail.com> (https://github.com/sauzy34)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "example": "pnpm --filter @rn-multi-selectbox/example start",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:ci": "pnpm -r --if-present run test:ci",
    "lint": "pnpm -r --if-present run lint",
    "build": "pnpm -r --if-present run build",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules"
  },
  "keywords": [
    "react-native-select",
    "react-native",
    "react",
    "selectbox",
    "dropdown",
    "picker",
    "select",
    "expo",
    "monorepo"
  ],
  "pnpm": {
    "overrides": {
      "@babel/core": "7.26.10"
    }
  }
}
