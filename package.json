{
  "name": "ReactCore",
  "version": "0.0.1",
  "private": false,
  "description": "Platform independent (Android / iOS) Selectbox | Picker | Multi-select | Multi-picker. The idea is to bring out the common user-interface & user-experience on both platforms.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauzy34/react-native-multi-selectbox"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint **/*.{js,ts,tsx} --fix",
    "prettier": "prettier **/*.{js,ts,tsx}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-svg": "^15.8.0",
    "react-native-web": "~0.19.13",
    "@expo/metro-runtime": "~4.0.1",
    "react-native-multi-selectbox": "file:./lib"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/cli": "^0.18.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.73.0",
    "babel-preset-expo": "~12.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.0"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    }
  },
  "bugs": {
    "url": "https://github.com/sauzy34/react-native-multi-selectbox/issues"
  },
  "author": "Saurav Gupta <sonugupta34@gmail.com> (https://github.com/sauzy34)",
  "license": "MIT",
  "keywords": [
    "react-native-select",
    "react-native",
    "react",
    "selectbox",
    "dropdown",
    "picker",
    "select",
    "expo",
    "expo-picker",
    "expo-select",
    "expo-multi-select"
  ]
}
