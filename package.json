{
  "name": "react-native-multi-selectbox-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for react-native-multi-selectbox (library) and Expo example app.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauzy34/react-native-multi-selectbox.git"
  },
  "bugs": {
    "url": "https://github.com/sauzy34/react-native-multi-selectbox/issues"
  },
  "author": "Saurav Gupta <sonugupta34@gmail.com> (https://github.com/sauzy34)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "example": "pnpm --filter @rn-multi-selectbox/example start",
    "example:online": "pnpm --filter @rn-multi-selectbox/example start:online",
    "example:web": "pnpm --filter @rn-multi-selectbox/example web",
    "example:web:online": "pnpm --filter @rn-multi-selectbox/example web:online",
    "example:clear": "pnpm --filter @rn-multi-selectbox/example exec expo start --offline -c",
    "example:export:web": "pnpm --filter @rn-multi-selectbox/example export:web",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:ci": "pnpm -r --if-present run test:ci",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm -r --if-present run build",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules",
    "publish:lib": "pnpm --filter react-native-multi-selectbox publish --access public",
    "pack:lib": "pnpm --filter react-native-multi-selectbox exec npm pack"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1"
  },
  "keywords": [
    "react-native-select",
    "react-native",
    "react",
    "selectbox",
    "dropdown",
    "picker",
    "select",
    "expo",
    "monorepo"
  ]
}
